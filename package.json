{
  "name": "uncover-aoagents",
  "version": "0.1.0",
  "description": "A minimal reverse-engineered version of @aoagents' agent-orchestrator. Runs N coding agents in parallel using git worktrees and PATH-shim observability. ~400 lines of TypeScript.",
  "type": "module",
  "bin": {
    "uncover": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "uncover": "tsx src/index.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "agent-orchestrator",
    "aoagents",
    "parallel-agents",
    "git-worktree",
    "claude-code",
    "codex",
    "aider",
    "reverse-engineering"
  ]
}
